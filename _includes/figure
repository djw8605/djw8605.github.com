{% assign fig_path = include.image_path | remove_first: "/images/" %}
{% assign fig_alt = include.alt | default: "" %}
<figure class="{{ include.class }}">
  {% picture content {{ fig_path }} --alt {{ fig_alt }} --img loading="lazy" decoding="async" %}
  {%- if include.caption -%}
    <figcaption>
      {{ include.caption | markdownify | remove: "<p>" | remove: "</p>" }}
    </figcaption>
  {%- endif -%}
</figure>
